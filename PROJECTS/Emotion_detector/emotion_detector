#!/usr/bin/env python3.14
"""
Emotion Detection System - Python 3.14 Edition
Real-time facial emotion recognition using OpenCV
"""

from __future__ import annotations

import os
import sys
import warnings
from pathlib import Path
from typing import Optional
from collections import Counter
import asyncio
import random

import cv2
import numpy as np

# Suppress warnings
warnings.filterwarnings('ignore')
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '3'


class EmotionDetector:
    """Real-time emotion detection system using Haar Cascade."""
    
    EMOTIONS: tuple[str, ...] = (
        "Angry", "Disgust", "Fear", "Happy", "Sad", "Surprise", "Neutral"
    )
    
    MODEL_INPUT_SIZE: tuple[int, int] = (48, 48)
    MAX_FACES_PER_FRAME: int = 5
    
    def __init__(self, cascade_path: Path | str | None = None):
        """
        Initialize the emotion detector.
        
        Args:
            cascade_path: Path to Haar cascade XML file (uses OpenCV default if None)
        """
        self.cascade_path = Path(cascade_path) if cascade_path else None
        
        # Load cascade classifier
        self.face_cascade = self._load_cascade()
        
        # Statistics
        self.frame_count: int = 0
        self.detected_emotions: list[str] = []
        
    def _load_cascade(self) -> cv2.CascadeClassifier:
        """Load Haar cascade classifier with fallback options."""
        if self.cascade_path and self.cascade_path.exists():
            print(f"📁 Loading cascade from: {self.cascade_path}")
            cascade = cv2.CascadeClassifier(str(self.cascade_path))
            if not cascade.empty():
                print("✓ Cascade loaded successfully")
                return cascade
        
        # Fallback to OpenCV's built-in cascade
        cascade_alt = cv2.data.haarcascades + "haarcascade_frontalface_default.xml"
        print(f"📁 Loading cascade from OpenCV default: {cascade_alt}")
        cascade = cv2.CascadeClassifier(cascade_alt)
        
        if cascade.empty():
            raise RuntimeError("❌ Could not load Haar cascade file from any source")
        
        print("✓ Cascade loaded successfully (OpenCV default)")
        return cascade
    
    def detect_emotion(self, face_roi: np.ndarray) -> tuple[str, float]:
        """
        Detect emotion from a face ROI.
        Using random emotions for testing (replace with real model later).
        
        Args:
            face_roi: Grayscale face region (any size)
        
        Returns:
            Tuple of (emotion_label, confidence_percentage)
        """
        # For testing: return random emotion
        emotion = random.choice(self.EMOTIONS)
        confidence = random.uniform(70, 99)
        return emotion, confidence
    
    def process_frame(self, frame: np.ndarray) -> tuple[np.ndarray, int]:
        """
        Process a frame and detect emotions.
        
        Args:
            frame: Input frame from webcam
        
        Returns:
            Tuple of (annotated_frame, num_faces_detected)
        """
        self.frame_count += 1
        
        # Mirror the frame
        frame = cv2.flip(frame, 1)
        
        # Convert to grayscale
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        
        # Detect faces
        faces = self.face_cascade.detectMultiScale(
            gray,
            scaleFactor=1.3,
            minNeighbors=5,
            minSize=(30, 30)
        )
        
        faces_detected = len(faces)
        
        # Process each detected face
        for idx, (x, y, w, h) in enumerate(faces[:self.MAX_FACES_PER_FRAME]):
            try:
                # Extract ROI
                roi_gray = gray[y:y+h, x:x+w]
                
                # Detect emotion
                emotion, confidence = self.detect_emotion(roi_gray)
                self.detected_emotions.append(emotion)
                
                # Draw bounding box (green)
                cv2.rectangle(frame, (x, y), (x+w, y+h), (0, 255, 0), 2)
                
                # Draw label with confidence
                label = f"{emotion} ({confidence:.1f}%)"
                cv2.putText(
                    frame,
                    label,
                    (x, y - 10),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.8,
                    (0, 255, 0),
                    2
                )
                
            except Exception as e:
                print(f"⚠️  Error processing face {idx}: {e}")
                continue
        
        # Draw frame counter
        cv2.putText(
            frame,
            f"Frame: {self.frame_count} | Faces: {faces_detected}",
            (10, 30),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.7,
            (255, 255, 255),
            2
        )
        
        return frame, faces_detected
    
    def print_statistics(self) -> None:
        """Print session statistics."""
        print("\n" + "="*60)
        print("📊 SESSION STATISTICS")
        print("="*60)
        print(f"Total frames processed: {self.frame_count}")
        print(f"Total faces detected: {len(self.detected_emotions)}")
        
        if self.detected_emotions:
            emotion_counts = Counter(self.detected_emotions)
            print(f"\n📈 Emotion Distribution:")
            for emotion, count in emotion_counts.most_common():
                percentage = (count / len(self.detected_emotions)) * 100
                print(f"  {emotion:12} : {count:3} ({percentage:5.1f}%)")
        print("="*60 + "\n")


async def open_webcam(camera_idx: int = 0) -> Optional[cv2.VideoCapture]:
    """
    Asynchronously attempt to open webcam.
    
    Args:
        camera_idx: Camera index to try
    
    Returns:
        VideoCapture object if successful, None otherwise
    """
    try:
        if camera_idx == 0:
            cap = cv2.VideoCapture(0, cv2.CAP_DSHOW)
        else:
            cap = cv2.VideoCapture(camera_idx)
        
        if cap and cap.isOpened():
            # Set camera properties
            cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
            cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
            cap.set(cv2.CAP_PROP_FPS, 30)
            return cap
    except Exception as e:
        print(f"  Camera index {camera_idx} failed: {e}")
    
    return None


def main() -> int:
    """
    Main entry point for the emotion detection system.
    
    Returns:
        Exit code (0 for success, 1 for failure)
    """
    cap = None
    detector = None
    
    try:
        # Determine base directory
        base_dir = Path(__file__).parent.resolve()
        
        # Define file paths
        cascade_path = base_dir / "haarcascade_frontalface_default.xml"
        
        # Initialize emotion detector
        print("\n" + "="*60)
        print("🚀 EMOTION DETECTION SYSTEM - Python 3.14")
        print("="*60 + "\n")
        
        detector = EmotionDetector(
            cascade_path=cascade_path if cascade_path.exists() else None
        )
        
        # Open webcam
        print("\n📹 Initializing webcam...")
        for idx in [0, -1]:
            cap = asyncio.run(open_webcam(idx))
            if cap:
                print(f"✓ Webcam opened successfully")
                break
        
        if not cap or not cap.isOpened():
            print("❌ Error: Could not open webcam.", file=sys.stderr)
            return 1
        
        # Print instructions
        print("\n" + "="*60)
        print("📋 CONTROLS")
        print("="*60)
        print("  Press 'q'  → Quit")
        print("  Press 's'  → Save screenshot")
        print("="*60)
        print("ℹ️  Testing with random emotions (no model loaded)")
        print("="*60 + "\n")
        
        # Main loop
        screenshot_count = 0
        
        while True:
            ret, frame = cap.read()
            
            if not ret:
                print("⚠️  Failed to read frame.")
                break
            
            # Process frame
            annotated_frame, faces_detected = detector.process_frame(frame)
            
            # Display
            cv2.imshow("Emotion Detection System | Press 'q' to quit", annotated_frame)
            
            # Handle key presses
            key = cv2.waitKey(1) & 0xFF
            if key == ord("q"):
                print("\n👋 Quitting...")
                break
            elif key == ord("s"):
                screenshot_count += 1
                filename = f"emotion_detection_{detector.frame_count}_{screenshot_count}.jpg"
                cv2.imwrite(filename, annotated_frame)
                print(f"📸 Screenshot saved: {filename}")
        
        return 0
        
    except KeyboardInterrupt:
        print("\n⚠️  Interrupted by user")
        return 0
    except RuntimeError as e:
        print(f"❌ {e}", file=sys.stderr)
        return 1
    except Exception as e:
        print(f"❌ Unexpected error: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        return 1
    finally:
        print("\n🧹 Cleaning up...")
        if cap:
            cap.release()
        cv2.destroyAllWindows()
        
        if detector:
            detector.print_statistics()
        
        print("✓ Emotion Detection System closed.\n")


if __name__ == "__main__":
    sys.exit(main())